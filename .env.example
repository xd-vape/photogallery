# PostgreSQL runtime connection.
DATABASE_URL="postgresql://postgres:change-me@localhost:5432/photogallery?schema=public"

# Generate two different values:
# node -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET="replace-with-an-independent-random-auth-secret"
GALLERY_ACCESS_SECRET="replace-with-an-independent-random-gallery-secret"

# Public URL through which users access the application.
# Use the external HTTPS URL behind your reverse proxy in production.
BETTER_AUTH_URL="http://localhost:3000"

# Explicitly choose local or s3.
STORAGE_DRIVER="local"

# Required when STORAGE_DRIVER=local.
LOCAL_STORAGE_DIR="./storage"

MAX_UPLOAD_MB="15"

# Required when STORAGE_DRIVER=s3.
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_FORCE_PATH_STYLE="true"