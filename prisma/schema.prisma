generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum GalleryStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum GalleryCoverStyle {
  CLASSIC
  MINIMAL
  BOLD
  SPLIT
  DARK
}

enum GalleryFontStyle {
  SERIF
  SANS
  MODERN
  TIMELESS
}

enum GalleryColorPalette {
  LIGHT
  GOLD
  ROSE
  SAND
  OLIVE
  DARK
}

enum GalleryGridSpacing {
  TIGHT
  REGULAR
  LARGE
}

enum SubscriptionPlan {
  FREE
  PRO
  STUDIO
  ENTERPRISE
}

enum SubscriptionStatus {
  NONE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

model user {
  id                               String             @id @default(cuid())
  name                             String
  email                            String             @unique
  emailVerified                    Boolean            @default(false)
  image                            String?

  role                             String             @default("user")
  banned                           Boolean?            @default(false)
  banReason                        String?
  banExpires                       DateTime?

  subscriptionPlan                 SubscriptionPlan   @default(FREE)
  subscriptionStatus               SubscriptionStatus @default(NONE)
  subscriptionCurrentPeriodEnd     DateTime?
  subscriptionProviderCustomerId   String?
  subscriptionProviderSubscriptionId String?

  createdAt                        DateTime           @default(now())
  updatedAt                        DateTime           @updatedAt
  
  sessions                         session[]
  accounts                         account[]
  galleries                        Gallery[]

  @@index([role])
  @@index([banned])
  @@index([subscriptionPlan, subscriptionStatus])
}

model session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  impersonatedBy String?

  userId    String
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([impersonatedBy])
}

model account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  user      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@unique([providerId, accountId])
}

model verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

model Gallery {
  id               String                @id @default(cuid())
  ownerId          String
  owner            user                  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title            String
  slug             String                @unique
  description      String?
  status           GalleryStatus         @default(DRAFT)
  eventDate        DateTime?
  passwordHash     String?
  expiresAt        DateTime?
  coverImageId     String?               @unique
  coverImage       Image?                @relation("GalleryCover", fields: [coverImageId], references: [id], onDelete: SetNull)
  downloadEnabled  Boolean               @default(false)
  coverStyle       GalleryCoverStyle     @default(CLASSIC)
  fontStyle        GalleryFontStyle      @default(SERIF)
  colorPalette     GalleryColorPalette   @default(LIGHT)
  gridColumns      Int                   @default(3)
  gridSpacing      GalleryGridSpacing    @default(REGULAR)
  sets             GallerySet[]
  images           Image[]               @relation("GalleryImages")
  submissions      FavoriteSubmission[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([ownerId, status])
}

model GallerySet {
  id        String   @id @default(cuid())
  galleryId String
  gallery   Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  name      String
  position  Int      @default(0)
  images    Image[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([galleryId, name])
  @@index([galleryId, position])
}

model Image {
  id            String         @id @default(cuid())
  galleryId     String
  gallery       Gallery        @relation("GalleryImages", fields: [galleryId], references: [id], onDelete: Cascade)
  setId         String?
  set           GallerySet?    @relation(fields: [setId], references: [id], onDelete: SetNull)
  coverFor      Gallery?       @relation("GalleryCover")
  originalKey   String
  displayKey    String
  thumbnailKey  String
  filename      String
  mimeType      String
  sizeBytes     Int
  width         Int
  height        Int
  position      Int
  favoriteItems FavoriteItem[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([galleryId, position])
  @@index([setId, position])
}

model FavoriteSubmission {
  id          String         @id @default(cuid())
  galleryId   String
  gallery     Gallery        @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  clientName  String
  clientEmail String
  items       FavoriteItem[]
  createdAt   DateTime       @default(now())

  @@index([galleryId, createdAt])
}

model FavoriteItem {
  id           String             @id @default(cuid())
  submissionId String
  submission   FavoriteSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  imageId      String
  image        Image              @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@unique([submissionId, imageId])
  @@index([imageId])
}
